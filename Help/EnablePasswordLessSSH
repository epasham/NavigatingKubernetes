# Generate SSH key on client
ssh-keygen -t rsa -b 4096 -f ~/.ssh/id_rsa
Press Enter for no passphrase (automation-friendly)

Creates:
private key: ~/.ssh/id_rsa
public key: ~/.ssh/id_rsa.pub

# Copy SSH public key to the server
ssh-copy-id appuser@remote-host
OR
cat ~/.ssh/id_rsa.pub | ssh appuser@remote-host \
  "mkdir -p ~/.ssh && cat >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys"
  
cat ~/.ssh/id_rsa.pub | ssh appadmin@10.x.x.x \
  "mkdir -p ~/.ssh && cat >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys"
  
# Now you can login without a password:
ssh appadmin@10.x.x.x
